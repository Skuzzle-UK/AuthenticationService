<?xml version="1.0" encoding="utf-8"?>
<!--
    Repo-root NuGet config. The <clear/> drops any package sources inherited from a
    user-level or machine-level NuGet.Config so this repo only restores from public
    nuget.org. Important because:

      - This repo is public; we don't want references to private corporate feeds
        leaking into the source tree.
      - CI runners / contributors with their own NuGet configs all get the same
        deterministic restore behaviour — no "works on my machine because my user
        config has feed X" surprises.

    If a future package genuinely needs a private feed (NuGet.org doesn't carry it),
    add the source AND an entry in <packageSourceMapping> rather than a global add.
    Credentials should never be committed; use NuGet's environment-variable-driven
    credential mechanism in CI.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
