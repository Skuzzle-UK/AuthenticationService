{
  "HostingSettings": {
    "BackgroundWorkersEnabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "MySQL": "server=localhost;port=3306;database=AuthenticationService;user=root;password=password;",
    "Redis": "localhost:6379"
  },
  "AdminAccountSeedSettings": {
    // Password is intentionally absent from this file. Outside Development the service
    // refuses to start unless AdminAccountSeedSettings:Password is supplied via env var,
    // user-secrets, or a secret store (e.g. AdminAccountSeedSettings__Password=<value>).
    // appsettings.Development.json carries a dev-only default so `dotnet run` works
    // first time; that default is explicitly rejected in non-Development environments.
    "Email": "email@email.com",
    "FirstName": "Administrator",
    //"LastName": "",
    //"PhoneNumber": "",
    //"PhoneNumberConfirmed": false,
    "Country": "United Kingdom"
  },
  "JWTSettings": {
    "PrivateKeyDirectory": "keys",
    "ActiveKeyId": "auto",
    "ValidIssuer": "https://auth.example.com",
    "ValidAudience": "platform-api",
    "ExpiryInMinutes": 5,
    "RefreshTokenExpiryInDays": 5
  },
  "DataRetentionSettings": {
    "CleanupIntervalInHours": 12,
    "RevokedReplayTTLInDays": 90
  },
  "PublicUrlSettings": {
    // Public-facing base URL of this auth service — used by background workers (e.g. the
    // threshold-escalation lock email) to build links when there's no HttpContext to
    // derive the URL from. BaseUrl is intentionally absent here; outside Development the
    // service refuses to start unless PublicUrlSettings:BaseUrl is supplied via env var
    // / user-secrets / secret store. The dev-only default lives in
    // appsettings.Development.json.
  },
  "ThresholdEscalationSettings": {
    // Background worker that locks accounts when a revoked access token is replayed
    // repeatedly (an attacker hammering with a stolen token). Defaults are aggressive on
    // purpose — a well-behaved client retries at most once with a stale token before
    // refreshing. Loosen if you have legitimate retry-on-old-token churn (e.g. integration
    // tests against a single shared user). Set Enabled=false to disable entirely.
    "Enabled": true,
    "SweepIntervalInMinutes": 1,
    "WindowInMinutes": 5,
    "WarnThreshold": 2,
    "LockThreshold": 5
  },
  "DataProtectionSettings": {
    "RedisKey": "AuthService:DataProtectionKeys",
    "ApplicationName": "AuthenticationService"
    //"Certificate": {
    //  "PfxPath": "/run/secrets/data-protection.pfx",
    //  "PfxPassword": "<from-secret-store>"
    //}
  },
  "RunMigrationsAtStartup": true,
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "ForwardedHeadersSettings": {
    // Populate when deployed behind a load balancer / reverse proxy.
    // Local dev with no proxy can leave both lists empty.
    "KnownNetworks": [
      //"10.0.0.0/8"
    ],
    "KnownProxies": [
      //"203.0.113.10"
    ]
  },
  "EmailServerSettings": {
    "From": "email@email.com",
    "SmtpServer": "localhost",
    "Port": "587",
    "UserName": "email@email.com",
    "Password": "Pa5$word123"
  },
  "AllowedHosts": "*"
}
