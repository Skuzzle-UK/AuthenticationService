{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "MySQL": "server=localhost;port=3306;database=AuthenticationService;user=root;password=password;",
    "Redis": "localhost:6379"
  },
  "AdminAccountSeedSettings": {
    // Password is intentionally absent from this file. Outside Development the service
    // refuses to start unless AdminAccountSeedSettings:Password is supplied via env var,
    // user-secrets, or a secret store (e.g. AdminAccountSeedSettings__Password=<value>).
    // appsettings.Development.json carries a dev-only default so `dotnet run` works
    // first time; that default is explicitly rejected in non-Development environments.
    "Email": "email@email.com",
    "FirstName": "Administrator",
    //"LastName": "",
    //"PhoneNumber": "",
    //"PhoneNumberConfirmed": false,
    "Country": "United Kingdom"
  },
  "JWTSettings": {
    "PrivateKeyDirectory": "keys",
    "ActiveKeyId": "auto",
    "ValidIssuer": "https://auth.example.com",
    "ValidAudience": "platform-api",
    "ExpiryInMinutes": 5,
    "RefreshTokenExpiryInDays": 5
  },
  "DataRetentionSettings": {
    "CleanupIntervalInHours": 12,
    "RevokedReplayTTLInDays": 90
  },
  "DataProtectionSettings": {
    "RedisKey": "AuthService:DataProtectionKeys",
    "ApplicationName": "AuthenticationService"
    //"Certificate": {
    //  "PfxPath": "/run/secrets/data-protection.pfx",
    //  "PfxPassword": "<from-secret-store>"
    //}
  },
  "RunMigrationsAtStartup": true,
  "CorsSettings": {
    // Origins allowed to call this API from a browser. Production: explicit list of
    // platform front-end origins (e.g. "https://app.example.com"). Empty list blocks all
    // cross-origin traffic. See appsettings.Development.json for local-dev defaults.
    "AllowedOrigins": []
  },
  "ForwardedHeadersSettings": {
    // Populate when deployed behind a load balancer / reverse proxy.
    // Local dev with no proxy can leave both lists empty.
    "KnownNetworks": [
      //"10.0.0.0/8"
    ],
    "KnownProxies": [
      //"203.0.113.10"
    ]
  },
  "EmailServerSettings": {
    "From": "email@email.com",
    "SmtpServer": "localhost",
    "Port": "587",
    "UserName": "email@email.com",
    "Password": "Pa5$word123"
  },
  "AllowedHosts": "*"
}
