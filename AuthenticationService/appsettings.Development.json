{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AdminAccountSeedSettings": {
    // Dev-only default so `dotnet run` works first time without anyone having to think
    // about credentials. The settings validator rejects this exact value in non-Development
    // environments — operators must override AdminAccountSeedSettings:Password explicitly.
    "Password": "Pa5$word123-dev"
  },
  "PublicUrlSettings": {
    // Where the dev auth service is reachable from a browser. Used by background workers
    // (e.g. threshold-escalation lock email) to build links — they have no HttpContext.
    // Production requires the canonical https URL (set via env var / secret store).
    "BaseUrl": "https://localhost:53217"
  },
  "EmailServerSettings": {
    // Dev-only SMTP password so `dotnet run` works first time. Production deployments
    // override via env var / user-secrets / secret store.
    "From": "email@email.com",
    "SmtpServer": "localhost",
    "Port": "587",
    "UserName": "email@email.com",
    "Password": "Pa5$word123-dev"
  },
  "CorsSettings": {
    // Common dev frontend ports — covers React (CRA / Next on 3000), Angular CLI (4200),
    // and Vite (5173). Add or remove entries to match your actual dev frontend setup.
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  }
}
