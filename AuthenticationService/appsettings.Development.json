{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CorsSettings": {
    // Common dev frontend ports — covers React (CRA / Next on 3000), Angular CLI (4200),
