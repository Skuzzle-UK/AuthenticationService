    "/.well-known/jwks.json": {
      "get": {
        "tags": [
          "WellKnown"
        ],
        "summary": "Returns every public signing key the service currently knows about. During key\r\nrotation the active key plus any predecessors are all published here so consumers\r\ncan validate tokens issued by any of them — the JWT's `kid` header tells\r\nJwtBearer which to use.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/.well-known/openid-configuration": {
      "get": {
        "tags": [
          "WellKnown"
        ],
        "summary": "Minimal OIDC discovery document. Lets consumers configure JwtBearer with just `Authority`.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
