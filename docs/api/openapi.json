{
  "openapi": "3.0.4",
  "info": {
    "title": "Authentication API",
    "version": "v1"
  },
  "paths": {
    "/api/Account/me": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Returns the logged-in user's profile + roles. A 200 means the token is valid and the user still exists.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Account"
        ],
        "summary": "Updates editable profile fields on the logged-in user. Body fields are optional; only supplied ones are written. Changing PhoneNumber resets the phone-confirmed flag.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/enablemfa": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Starts MFA enrolment. Returns a shared secret + QR code for authenticator apps, or verification details for email/phone providers.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnableMfaRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EnableMfaRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EnableMfaRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/forgotpassword": {
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Starts the forgot-password flow. Returns 200 even for unknown emails — don't leak which addresses are registered.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/forgotpassword/reset": {
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Sets a new password using the forgot-password email token. Also clears active lockouts — doubles as account-recovery.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetForgottenPasswordDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetForgottenPasswordDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ResetForgottenPasswordDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/changepassword": {
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Changes the logged-in user's password. User is identified from the token's sub claim — body email is ignored for identity.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/lock": {
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "\"Wasn't me!\" — landing point for the password-changed email link. Locks the account and emails the owner a reset link.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LockAccountDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LockAccountDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LockAccountDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Paginated list of users with optional filters (search, locked-only, unconfirmed-only).",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lockedOnly",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "unconfirmedOnly",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Creates a user via the invitation flow. Account is unusable until the user clicks the email link and sets a password.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateUserDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateUserDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateUserDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Full detail for a single user — profile, lockout, MFA, roles, active session count.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/resend-invitation": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Re-sends the invitation email. Returns 409 if the user has already activated their account.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/lock": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Locks a user account indefinitely. Refuses self-target.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/unlock": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Lifts an active lockout and resets the failed-attempt counter. Refuses self-target (admins use the seed-account recovery path).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/revoke-sessions": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Revokes every active session — refresh-token families + rotates security stamp. Doesn't lock the account; user can sign back in.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/reset-mfa": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Disables MFA and clears the authenticator key — helpdesk lost-phone recovery. Revokes all sessions implicitly.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/force-password-reset": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Generates a reset token, emails it, and revokes existing sessions. Admin never sees the new password.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForcePasswordResetRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ForcePasswordResetRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ForcePasswordResetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/users/{id}/audit": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Paginated audit log for the user. Reads `SecurityEvents`; defaults to the last 30 days.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          },
          {
            "name": "since",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "eventId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Creates a new OAuth client. Plaintext secret is returned <em>once</em> in the response — only the hash is persisted.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateClientDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateClientDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdminCreateClientDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Paginated list of clients with optional `activeOnly` filter.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          },
          {
            "name": "activeOnly",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients/{id}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Full detail for a single client — metadata + scopes list. Never includes the secret hash.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients/{id}/rotate-secret": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Generates a fresh secret and overwrites the stored hash. Response carries the new plaintext — same one-time-display contract as create.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients/{id}/disable": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Soft-disable the client. Subsequent /oauth/token attempts return invalid_client. Idempotent.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients/{id}/scopes": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Add an (audience, scope) tuple to a client. Idempotent.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminClientScopeDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminClientScopeDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdminClientScopeDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Admin/clients/{id}/scopes/{audience}/{scope}": {
      "delete": {
        "tags": [
          "Admin"
        ],
        "summary": "Remove a (audience, scope) tuple from a client. Returns 404 if the tuple wasn't present.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "audience",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Authentication/authenticate": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login. Returns access + refresh tokens on success, or kicks off the MFA challenge if MFA is enabled.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthenticationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthenticationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AuthenticationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Authentication/mfa": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Step 2 of MFA login. Verifies the user-supplied code and returns access + refresh tokens on success.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MfaAuthenticationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MfaAuthenticationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MfaAuthenticationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Authentication/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Swaps an expired access token + refresh token for a fresh pair. Reuse of a refresh token is treated as theft — every session for the user is revoked.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Authentication/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logs the caller out of this device only. Revokes the refresh-token family from the sid claim and deny-lists the current access token.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Authentication/logoutall": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logs the caller out of every device. Revokes all refresh-token families, rotates the security stamp, and deny-lists the current access token.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "tags": [
          "OAuth"
        ],
        "summary": "RFC 6749 §4.4 client-credentials grant.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "Must be `\"client_credentials\"`."
                  },
                  "client_id": {
                    "type": "string",
                    "description": "The client_id. Optional if supplied via Basic auth header."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "The client_secret. Optional if supplied via Basic auth header."
                  },
                  "audience": {
                    "type": "string",
                    "description": "Target audience for the token (e.g. `inventory-api`). Required. A token is scoped to a single audience."
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-separated list of scopes. Required. Every scope must be in the client's allow-list for AuthenticationService.Controllers.OAuthTokenRequest.Audience or the request fails with `invalid_scope`."
                  }
                }
              },
              "encoding": {
                "grant_type": {
                  "style": "form"
                },
                "client_id": {
                  "style": "form"
                },
                "client_secret": {
                  "style": "form"
                },
                "audience": {
                  "style": "form"
                },
                "scope": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Registration/register": {
      "post": {
        "tags": [
          "Registration"
        ],
        "summary": "Creates a new user and emails them a confirmation link. The account can't log in until the link is clicked.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Registration/confirm/email": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Landing point for the registration confirmation link. Marks the email confirmed, rotates the security stamp so the link can't be reused, then redirects to callbackUri.",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "token",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "callbackUri",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Registration"
        ],
        "summary": "Resends the email-confirmation link. Returns 200 even for unknown emails — don't leak which addresses are registered.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResendEmailConfirmationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ResendEmailConfirmationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ResendEmailConfirmationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Registration/accept-invitation": {
      "post": {
        "tags": [
          "Registration"
        ],
        "summary": "Completes the admin-invite flow. Sets the password and confirms email in one step. Returns 400 invitation_invalid (unknown email or bad token — single shape so we don't leak which emails exist) or 409 invitation_already_used.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInvitationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInvitationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInvitationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
