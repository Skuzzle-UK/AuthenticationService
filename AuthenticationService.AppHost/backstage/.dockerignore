# .dockerignore for our build-inside-container Dockerfile.
#
# Replaces the .dockerignore that @backstage/create-app ships. The default one
# excludes packages/*/src and *.local.yaml because it was designed for the
# create-app default Dockerfile (which packages pre-built tarballs and never
# touches source). Our multi-stage Dockerfile does the build INSIDE the
# container -- yarn tsc + yarn build:backend require the source AND the
# overlay app-config.local.yaml -- so we need both copied into the image.
#
# Copied into local-backstage/.dockerignore by scripts/setup-local-backstage.{ps1,sh}.

.git
.gitignore

# yarn caches / state -- regenerated by `yarn install` inside the container
.yarn/cache
.yarn/install-state.gz

# node_modules at every level -- yarn install rebuilds them inside the image
node_modules
packages/*/node_modules
plugins/*/node_modules

# Build outputs -- recreated by `yarn build:backend`
packages/*/dist
packages/*/dist-types
packages/*/build

# Editor / OS junk
.vscode
.idea
.DS_Store
Thumbs.db

# Test / coverage artefacts
coverage
*.log
