{
  "uid": "auth-overview",
  "title": "Auth Service Overview",
  "tags": ["auth"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Login rate (success vs failure)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (result) (rate(auth_logins_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 2,
      "title": "Login failure %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(auth_logins_total{result=\"failure\"}[5m])) / clamp_min(sum(rate(auth_logins_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Refresh-token reuse (last hour)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Every increment is a security incident. Should be 0 outside reuse-detection integration tests.",
      "targets": [
        { "expr": "sum(increase(auth_refresh_reuse_detected_total[1h]))", "refId": "A" }
      ],
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Threshold-escalation locks (last 24h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Accounts auto-locked due to sustained revoked-token replay. Alert-worthy.",
      "targets": [
        { "expr": "sum(increase(auth_threshold_escalation_fires_total{level=\"locked\"}[24h]))", "refId": "A" }
      ],
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Active lockouts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "auth_users_locked_total", "refId": "A" }
      ],
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 3 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "Total users",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "auth_users_total", "refId": "A" }
      ],
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "MFA adoption %",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * auth_users_mfa_enabled_total / clamp_min(auth_users_total, 1)",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Refresh-token rotations / min",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "60 * sum(rate(auth_refreshes_total[5m]))", "legendFormat": "rotations/min", "refId": "A" }
      ],
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "HTTP request rate by route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 10,
      "title": "p95 request latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{http_route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 11,
      "title": "Password resets (requested vs completed)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (stage) (rate(auth_password_resets_total[15m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 12,
      "title": "Tokens revoked by reason",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(auth_tokens_revoked_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
